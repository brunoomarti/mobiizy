<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".activities.RenterHomeActivity">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingTop="30dp"
        android:paddingHorizontal="@dimen/app_padding_horizontal">

        <LinearLayout
            android:id="@+id/dashboardHeaderTextContainer"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="12dp"
            android:orientation="vertical"
            app:layout_constraintEnd_toStartOf="@id/dashboardHomeAvatarCard"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_goneMarginEnd="0dp">

            <TextView
                android:id="@+id/tvDashboardTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="?attr/textPrimary"
                android:textSize="30sp"
                android:textStyle="bold"
                tools:text="@string/nav_home" />

            <TextView
                android:id="@+id/tvDashboardSubtitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="?attr/textSecondary"
                android:textSize="16sp"
                android:visibility="gone"
                tools:text="@string/renter_home_fragment_subtitle"
                tools:visibility="visible" />

        </LinearLayout>

        <FrameLayout
            android:id="@+id/dashboardHomeAvatarCard"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_marginTop="2dp"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:visibility="gone"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="@id/dashboardHeaderTextContainer"
            app:layout_constraintTop_toTopOf="@id/dashboardHeaderTextContainer"
            tools:visibility="visible">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:cardCornerRadius="30dp"
                app:cardElevation="0dp"
                app:strokeColor="?attr/borderLight"
                app:strokeWidth="1dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <androidx.appcompat.widget.AppCompatImageView
                        android:id="@+id/ivDashboardHomeAvatar"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:contentDescription="@string/dashboard_home_avatar_content_description"
                        android:scaleType="centerCrop"
                        android:visibility="gone"
                        tools:src="@drawable/car_sedan"
                        tools:visibility="visible" />

                    <TextView
                        android:id="@+id/tvDashboardHomeAvatarFallback"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:fontFamily="@font/material_symbols_rounded"
                        android:gravity="center"
                        android:text="person"
                        android:textColor="?attr/textSecondary"
                        android:textSize="26sp" />
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/dashboardHomeAvatarSyncBadge"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_gravity="top|end"
                android:layout_marginTop="2dp"
                android:layout_marginEnd="2dp"
                android:contentDescription="@string/profile_photo_pending_sync_content_description"
                android:visibility="gone"
                app:cardBackgroundColor="@android:color/white"
                app:cardCornerRadius="8dp"
                app:cardElevation="3dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:fontFamily="@font/material_symbols_rounded"
                    android:gravity="center"
                    android:text="cloud_off"
                    android:textColor="?attr/textSecondary"
                    android:textSize="11sp" />
            </com.google.android.material.card.MaterialCardView>
        </FrameLayout>

        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/dashboardFragmentContainer"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginTop="32dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/dashboardHeaderTextContainer" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <FrameLayout
        android:id="@+id/fullscreenMapOverlay"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="?attr/colorSurface"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <FrameLayout
            android:id="@+id/fullscreenMapContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <LinearLayout
            android:id="@+id/fullscreenLocationControls"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="top"
            android:layout_marginStart="68dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="16dp"
            android:orientation="vertical"
            android:visibility="gone">

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/btnFullscreenChangeLocation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackground"
                app:cardBackgroundColor="?attr/colorSurface"
                app:cardCornerRadius="14dp"
                app:cardElevation="4dp"
                app:strokeColor="?attr/borderLight"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="12dp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvFullscreenLocationTitle"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:textColor="?attr/textPrimary"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            tools:text="Rua Augusta, 1200 - Sao Paulo" />

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="@string/renter_home_change_location"
                            android:textColor="?attr/textSecondary"
                            android:textSize="12sp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/material_symbols_rounded"
                        android:text="chevron_right"
                        android:textColor="?attr/textSecondary"
                        android:textSize="24sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <LinearLayout
                android:id="@+id/fullscreenLocationSearchContainer"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginTop="2dp"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:visibility="gone">

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/fullscreenLocationSearchLayout"
                    style="@style/AppTextInputDropdown"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:hint="@string/hint_search_address"
                    app:boxBackgroundColor="?attr/colorSurface">

                    <com.google.android.material.textfield.MaterialAutoCompleteTextView
                        android:id="@+id/fullscreenLocationSearchInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:imeOptions="actionSearch"
                        android:inputType="text" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/btnFullscreenUseCurrentLocation"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_gravity="center_vertical"
                    android:layout_marginStart="8dp"
                    android:clickable="true"
                    android:contentDescription="@string/renter_home_use_current_location"
                    android:focusable="true"
                    app:cardBackgroundColor="?attr/colorSurface"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="1dp"
                    app:strokeColor="?attr/borderLight"
                    app:strokeWidth="1dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:fontFamily="@font/material_symbols_rounded"
                        android:gravity="center"
                        android:text="my_location"
                        android:textColor="?attr/textPrimary"
                        android:textSize="22sp" />
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>

        </LinearLayout>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/btnCloseFullscreenMap"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:layout_gravity="top|start"
            android:layout_marginTop="22dp"
            android:layout_marginStart="16dp"
            android:clickable="true"
            android:contentDescription="@string/renter_map_close"
            android:focusable="true"
            app:cardBackgroundColor="?attr/colorSurface"
            app:cardCornerRadius="22dp"
            app:cardElevation="4dp"
            app:strokeColor="?attr/borderLight"
            app:strokeWidth="1dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="X"
                android:textColor="?attr/textPrimary"
                android:textSize="16sp"
                android:textStyle="bold" />

        </com.google.android.material.card.MaterialCardView>
    </FrameLayout>

    <View
        android:id="@+id/bottomNavScrim"
        android:layout_width="match_parent"
        android:layout_height="156dp"
        android:layout_gravity="bottom"
        android:background="@drawable/bg_bottom_nav_scrim"
        android:importantForAccessibility="no" />

    <include
        android:id="@+id/floatingBottomNav"
        layout="@layout/view_floating_bottom_nav"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="20dp" />

</FrameLayout>
