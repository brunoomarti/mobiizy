<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ScrollView
        android:id="@+id/contentScroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/bottomActions"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/app_padding_horizontal"
            android:paddingTop="18dp"
            android:paddingEnd="@dimen/app_padding_horizontal"
            android:paddingBottom="18dp">

            <TextView
                android:id="@+id/btnBack"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:clickable="true"
                android:focusable="true"
                android:foreground="?attr/selectableItemBackgroundBorderless"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"
                android:text="@string/provider_vehicle_details_back"
                android:textColor="?attr/textSecondary"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/provider_vehicle_details_title"
                android:textColor="?attr/textPrimary"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="@string/provider_vehicle_details_subtitle"
                android:textColor="?attr/textSecondary"
                android:textSize="14sp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="1dp"
                app:strokeColor="?attr/borderLight"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/tvVehicleName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="?attr/textPrimary"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvVehicleStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:background="@drawable/bg_bottom_nav_item_selected"
                        android:paddingStart="10dp"
                        android:paddingTop="4dp"
                        android:paddingEnd="10dp"
                        android:paddingBottom="4dp"
                        android:textColor="?attr/colorOnSecondary"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tvVehicleInfo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:textColor="?attr/textSecondary"
                        android:textSize="14sp" />
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardVehiclePhotos"
                android:layout_width="match_parent"
                android:layout_height="240dp"
                android:layout_marginTop="14dp"
                app:cardCornerRadius="14dp"
                app:cardElevation="1dp"
                app:strokeColor="?attr/borderLight"
                app:strokeWidth="1dp">

                <FrameLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">

                    <ImageView
                        android:id="@+id/ivVehiclePhotoCarousel"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:background="?attr/colorSurface"
                        android:contentDescription="@string/provider_vehicle_details_photo_content_description"
                        android:scaleType="centerCrop" />

                    <TextView
                        android:id="@+id/tvVehiclePhotosEmpty"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:padding="20dp"
                        android:text="@string/provider_vehicle_details_photos_empty"
                        android:textColor="?attr/textSecondary"
                        android:textSize="14sp"
                        android:visibility="gone" />

                    <com.google.android.material.progressindicator.CircularProgressIndicator
                        android:id="@+id/progressVehiclePhoto"
                        android:layout_width="38dp"
                        android:layout_height="38dp"
                        android:layout_gravity="center"
                        android:visibility="gone"
                        app:indicatorColor="?attr/textSecondary" />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/btnPrevPhoto"
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        android:layout_gravity="start|center_vertical"
                        android:layout_marginStart="10dp"
                        android:background="@drawable/bg_photo_nav_button"
                        android:clickable="true"
                        android:contentDescription="@string/provider_vehicle_details_photo_previous"
                        android:focusable="true"
                        android:fontFamily="@font/material_symbols_rounded"
                        android:fontFeatureSettings="'liga'"
                        android:fontVariationSettings="'FILL' 1, 'wght' 500, 'GRAD' 0, 'opsz' 24"
                        android:gravity="center"
                        android:text="chevron_left"
                        android:textColor="?attr/textPrimary"
                        android:textSize="24sp" />

                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/btnNextPhoto"
                        android:layout_width="42dp"
                        android:layout_height="42dp"
                        android:layout_gravity="end|center_vertical"
                        android:layout_marginEnd="10dp"
                        android:background="@drawable/bg_photo_nav_button"
                        android:clickable="true"
                        android:contentDescription="@string/provider_vehicle_details_photo_next"
                        android:focusable="true"
                        android:fontFamily="@font/material_symbols_rounded"
                        android:fontFeatureSettings="'liga'"
                        android:fontVariationSettings="'FILL' 1, 'wght' 500, 'GRAD' 0, 'opsz' 24"
                        android:gravity="center"
                        android:text="chevron_right"
                        android:textColor="?attr/textPrimary"
                        android:textSize="24sp" />

                    <LinearLayout
                        android:id="@+id/photoDotsContainer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="bottom|center_horizontal"
                        android:layout_marginBottom="10dp"
                        android:orientation="horizontal" />
                </FrameLayout>
            </com.google.android.material.card.MaterialCardView>
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:id="@+id/bottomActions"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="@dimen/app_padding_horizontal"
        android:paddingTop="12dp"
        android:paddingEnd="@dimen/app_padding_horizontal"
        android:paddingBottom="18dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <Button
            android:id="@+id/btnEditListing"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="@string/provider_vehicle_details_edit_listing" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
