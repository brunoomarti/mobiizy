<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".activities.RegisterActivity">

    <!-- Stepper -->
    <LinearLayout
        android:id="@+id/dots_indicator"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="@dimen/app_padding_horizontal"
        android:paddingEnd="@dimen/app_padding_horizontal"
        android:paddingTop="32dp"
        android:paddingBottom="18dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- Step 1 -->
        <FrameLayout
            android:id="@+id/step1"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:background="@drawable/step_current" />

        <!-- Line 1 -->
        <View
            android:id="@+id/line1"
            android:layout_width="0dp"
            android:layout_height="2dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="8dp"
            android:background="@drawable/line_pending" />

        <!-- Step 2 -->
        <FrameLayout
            android:id="@+id/step2"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:background="@drawable/step_pending" />

        <!-- Line 2 -->
        <View
            android:id="@+id/line2"
            android:layout_width="0dp"
            android:layout_height="2dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="8dp"
            android:background="@drawable/line_pending" />

        <!-- Step 3 -->
        <FrameLayout
            android:id="@+id/step3"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:background="@drawable/step_pending" />

        <!-- Line 3 -->
        <View
            android:id="@+id/line3"
            android:layout_width="0dp"
            android:layout_height="2dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="8dp"
            android:background="@drawable/line_pending" />

        <!-- Step 4 -->
        <FrameLayout
            android:id="@+id/step4"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:background="@drawable/step_pending" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/step_header"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="@dimen/app_padding_horizontal"
        android:paddingEnd="@dimen/app_padding_horizontal"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        app:layout_constraintTop_toBottomOf="@id/dots_indicator"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvStepTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/register_step_initial"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/md_theme_light_textMuted" />

        <TextView
            android:id="@+id/btnCancel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/register_cancel"
            android:textSize="13sp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?attr/selectableItemBackgroundBorderless"
            android:textColor="@color/md_theme_light_textSecondary" />
    </LinearLayout>

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/view_pager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/step_header"
        app:layout_constraintBottom_toTopOf="@id/step_actions" />

    <LinearLayout
        android:id="@+id/step_actions"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingStart="@dimen/app_padding_horizontal"
        android:paddingEnd="@dimen/app_padding_horizontal"
        android:paddingTop="28dp"
        android:paddingBottom="18dp"
        android:gravity="center_vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <Button
            android:id="@+id/btnBack"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="@string/register_back" />

        <Space
            android:layout_width="12dp"
            android:layout_height="1dp" />

        <Button
            android:id="@+id/btnNext"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_weight="1"
            android:text="@string/register_next" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
