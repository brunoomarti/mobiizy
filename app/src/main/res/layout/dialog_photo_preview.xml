<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/previewBackdrop"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#CC000000"
    android:clickable="true"
    android:focusable="true"
    android:padding="20dp">

    <ImageView
        android:id="@+id/ivPhotoPreview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:adjustViewBounds="true"
        android:contentDescription="@string/vehicle_view_photo_button"
        android:scaleType="fitCenter" />

    <com.google.android.material.progressindicator.CircularProgressIndicator
        android:id="@+id/progressPhotoPreview"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_gravity="center"
        android:indeterminate="true" />

    <ImageButton
        android:id="@+id/btnClosePhotoPreview"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_gravity="top|end"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/vehicle_close_photo_preview"
        android:padding="8dp"
        android:src="@drawable/ic_close_24"
        android:tint="@android:color/white" />

</FrameLayout>
