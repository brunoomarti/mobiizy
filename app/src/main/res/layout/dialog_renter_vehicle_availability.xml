<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="24dp"    android:paddingTop="22dp"
    android:paddingEnd="24dp"
    android:paddingBottom="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/tvAvailabilityTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/renter_vehicle_details_calendar_title"
            android:textColor="?attr/textPrimary"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnCloseCalendar"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_photo_nav_button"
            android:fontFamily="@font/material_symbols_rounded"
            android:fontFeatureSettings="'liga'"
            android:fontVariationSettings="'FILL' 1, 'wght' 500, 'GRAD' 0, 'opsz' 24"
            android:gravity="center"
            android:text="close"
            android:textColor="?attr/textPrimary"
            android:textSize="20sp" />
    </LinearLayout>

    <TextView
        android:id="@+id/tvAvailabilitySubtitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="@string/renter_vehicle_details_calendar_subtitle"
        android:textColor="?attr/textSecondary"
        android:textSize="13sp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="14dp"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/btnPrevMonth"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_photo_nav_button"
            android:fontFamily="@font/material_symbols_rounded"
            android:fontFeatureSettings="'liga'"
            android:fontVariationSettings="'FILL' 1, 'wght' 500, 'GRAD' 0, 'opsz' 24"
            android:gravity="center"
            android:text="chevron_left"
            android:textColor="?attr/textPrimary"
            android:textSize="20sp" />

        <TextView
            android:id="@+id/tvCurrentMonth"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:textColor="?attr/textPrimary"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/btnNextMonth"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@drawable/bg_photo_nav_button"
            android:fontFamily="@font/material_symbols_rounded"
            android:fontFeatureSettings="'liga'"
            android:fontVariationSettings="'FILL' 1, 'wght' 500, 'GRAD' 0, 'opsz' 24"
            android:gravity="center"
            android:text="chevron_right"
            android:textColor="?attr/textPrimary"
            android:textSize="20sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutWeekdayHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvAvailabilityCalendar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:nestedScrollingEnabled="false" />

    <TextView
        android:id="@+id/tvSelectedDatesSummary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="@string/renter_vehicle_details_calendar_selected_none"
        android:textColor="?attr/textSecondary"
        android:textSize="13sp" />

    <Button
        android:id="@+id/btnViewQuote"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginTop="10dp"
        android:enabled="false"
        android:text="@string/renter_vehicle_details_view_quote" />

</LinearLayout>
