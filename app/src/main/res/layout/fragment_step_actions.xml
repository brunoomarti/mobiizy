<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="@dimen/app_padding_horizontal"
    android:paddingTop="28dp"
    android:paddingEnd="@dimen/app_padding_horizontal"
    android:paddingBottom="18dp">

    <Button
        android:id="@+id/btnBack"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_weight="1"
        android:text="@string/register_back" />

    <Space
        android:layout_width="12dp"
        android:layout_height="1dp" />

    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_weight="1">

        <Button
            android:id="@+id/btnNext"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="@string/register_next" />

        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:id="@+id/progressBtnNext"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_gravity="center"
            android:elevation="8dp"
            android:indeterminate="true"
            android:translationZ="8dp"
            android:visibility="gone"
            app:indicatorColor="?attr/colorOnPrimary"
            app:indicatorInset="0dp"
            app:indicatorSize="20dp"
            app:trackColor="@color/progress_btn_next_track"
            app:trackThickness="2dp" />
    </FrameLayout>

</LinearLayout>
