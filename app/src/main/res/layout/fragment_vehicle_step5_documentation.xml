<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingStart="@dimen/app_padding_horizontal"
    android:paddingEnd="@dimen/app_padding_horizontal">

    <include
        android:id="@+id/headerStep5"
        layout="@layout/view_step_header"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ScrollView
        android:id="@+id/step5Scroll"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerStep5">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/vehicle_field_docs_up_to_date"
                android:textColor="?attr/textPrimary"
                android:textStyle="bold" />

            <RadioGroup
                android:id="@+id/rgDocsUpToDate"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="horizontal">

                <com.google.android.material.radiobutton.MaterialRadioButton
                    android:id="@+id/rbDocsYes"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/common_yes"
                    app:buttonTint="@color/radio_button_tint"
                    app:useMaterialThemeColors="false" />

                <com.google.android.material.radiobutton.MaterialRadioButton
                    android:id="@+id/rbDocsNo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="@string/common_no"
                    app:buttonTint="@color/radio_button_tint"
                    app:useMaterialThemeColors="false" />
            </RadioGroup>

            <TextView
                android:id="@+id/tvDocsError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/error_required"
                android:textColor="?attr/error"
                android:textSize="12sp"
                android:visibility="gone" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="@string/vehicle_field_ipva_licensing_ok"
                android:textColor="?attr/textPrimary"
                android:textStyle="bold" />

            <RadioGroup
                android:id="@+id/rgIpva"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="horizontal">

                <com.google.android.material.radiobutton.MaterialRadioButton
                    android:id="@+id/rbIpvaYes"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/common_yes"
                    app:buttonTint="@color/radio_button_tint"
                    app:useMaterialThemeColors="false" />

                <com.google.android.material.radiobutton.MaterialRadioButton
                    android:id="@+id/rbIpvaNo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="@string/common_no"
                    app:buttonTint="@color/radio_button_tint"
                    app:useMaterialThemeColors="false" />
            </RadioGroup>

            <TextView
                android:id="@+id/tvIpvaError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/error_required"
                android:textColor="?attr/error"
                android:textSize="12sp"
                android:visibility="gone" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="@string/vehicle_field_insurance"
                android:textColor="?attr/textPrimary"
                android:textStyle="bold" />

            <RadioGroup
                android:id="@+id/rgInsurance"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:orientation="horizontal">

                <com.google.android.material.radiobutton.MaterialRadioButton
                    android:id="@+id/rbInsuranceYes"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/common_yes"
                    app:buttonTint="@color/radio_button_tint"
                    app:useMaterialThemeColors="false" />

                <com.google.android.material.radiobutton.MaterialRadioButton
                    android:id="@+id/rbInsuranceNo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="@string/common_no"
                    app:buttonTint="@color/radio_button_tint"
                    app:useMaterialThemeColors="false" />
            </RadioGroup>

            <TextView
                android:id="@+id/tvInsuranceError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/error_required"
                android:textColor="?attr/error"
                android:textSize="12sp"
                android:visibility="gone" />

            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/insuranceTypeLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:visibility="gone">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/insuranceTypeInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/vehicle_field_insurance_type_optional" />
            </com.google.android.material.textfield.TextInputLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginTop="14dp"
                android:background="?attr/borderLight" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:text="@string/vehicle_section_owner_rules"
                android:textColor="?attr/textPrimary"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvAllowPetLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/vehicle_field_allow_pet"
                android:textColor="?attr/textPrimary" />

            <RadioGroup
                android:id="@+id/rgAllowPet"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="horizontal">

                <com.google.android.material.radiobutton.MaterialRadioButton
                    android:id="@+id/rbAllowPetYes"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/common_yes"
                    app:buttonTint="@color/radio_button_tint"
                    app:useMaterialThemeColors="false" />

                <com.google.android.material.radiobutton.MaterialRadioButton
                    android:id="@+id/rbAllowPetNo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="@string/common_no"
                    app:buttonTint="@color/radio_button_tint"
                    app:useMaterialThemeColors="false" />
            </RadioGroup>

            <TextView
                android:id="@+id/tvAllowPetError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/error_required"
                android:textColor="?attr/error"
                android:textSize="12sp"
                android:visibility="gone" />

            <TextView
                android:id="@+id/tvAllowSmokingLabel"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/vehicle_field_allow_smoking"
                android:textColor="?attr/textPrimary" />

            <RadioGroup
                android:id="@+id/rgAllowSmoking"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="horizontal">

                <com.google.android.material.radiobutton.MaterialRadioButton
                    android:id="@+id/rbAllowSmokingYes"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/common_yes"
                    app:buttonTint="@color/radio_button_tint"
                    app:useMaterialThemeColors="false" />

                <com.google.android.material.radiobutton.MaterialRadioButton
                    android:id="@+id/rbAllowSmokingNo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="@string/common_no"
                    app:buttonTint="@color/radio_button_tint"
                    app:useMaterialThemeColors="false" />
            </RadioGroup>

            <TextView
                android:id="@+id/tvAllowSmokingError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/error_required"
                android:textColor="?attr/error"
                android:textSize="12sp"
                android:visibility="gone" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="@string/vehicle_field_allow_trip"
                android:textColor="?attr/textPrimary" />

            <RadioGroup
                android:id="@+id/rgAllowTrip"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="horizontal">

                <com.google.android.material.radiobutton.MaterialRadioButton
                    android:id="@+id/rbAllowTripYes"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/common_yes"
                    app:buttonTint="@color/radio_button_tint"
                    app:useMaterialThemeColors="false" />

                <com.google.android.material.radiobutton.MaterialRadioButton
                    android:id="@+id/rbAllowTripNo"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="16dp"
                    android:text="@string/common_no"
                    app:buttonTint="@color/radio_button_tint"
                    app:useMaterialThemeColors="false" />
            </RadioGroup>

            <TextView
                android:id="@+id/tvAllowTripError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/error_required"
                android:textColor="?attr/error"
                android:textSize="12sp"
                android:visibility="gone" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupTripTypes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:visibility="gone"
                app:chipSpacingHorizontal="8dp"
                app:chipSpacingVertical="8dp"
                app:singleLine="false" />

            <TextView
                android:id="@+id/tvTripTypesError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/vehicle_error_select_trip_type"
                android:textColor="?attr/error"
                android:textSize="12sp"
                android:visibility="gone" />

            <LinearLayout
                android:id="@+id/driverRequirementsRow"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/minDriverAgeLayout"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:tag="required">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/minDriverAgeInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/vehicle_field_min_driver_age"
                        android:inputType="number" />
                </com.google.android.material.textfield.TextInputLayout>

                <Space
                    android:layout_width="12dp"
                    android:layout_height="1dp" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/minCnhYearsLayout"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:tag="required">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/minCnhYearsInput"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="@string/vehicle_field_min_cnh_years"
                        android:inputType="number" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
